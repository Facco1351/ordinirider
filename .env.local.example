# ─── Supabase ────────────────────────────────────────────────────────
# Ottieni questi valori da: supabase.com → tuo progetto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── JWT Session ─────────────────────────────────────────────────────
# Genera una stringa random lunga (es: openssl rand -base64 32)
JWT_SECRET=cambia-questa-stringa-con-una-random-lunga-32-caratteri
